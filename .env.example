# Database Configuration
# Local Development (Docker)
DB_HOST=localhost
DB_PORT=54321
DB_NAME=whynot
DB_USER=postgres
DB_PASSWORD=postgres

# Production (Heroku) - Set these environment variables in Heroku Config Vars:
# DB_HOST=<heroku-postgres-host>
# DB_PORT=5432
# DB_NAME=<heroku-db-name>
# DB_USER=<heroku-db-user>
# DB_PASSWORD=<heroku-db-password>

# Redis Configuration
# Local Development (Docker)
REDIS_URL=redis://localhost:6379
# Production (Render) - Auto-populated from Render Redis service
# REDIS_URL=<auto-populated-by-render>

# Application
JWT_SECRET=your-secret-key-change-this-in-production
PORT=3000
NODE_ENV=development

# CORS (only needed in development)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Agora RTC
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate
AGORA_CUSTOMER_ID=your_agora_app_customer_id
AGORA_CUSTOMER_SECRET=your_agora_app_customer_secret

# Cloudflare Stream
CLOUDFLARE_STREAM_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_STREAM_API_TOKEN=your_cloudflare_api_token

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# AWS Configuration
AWS_S3_BUCKET=whynot-agora-recordings
AWS_S3_REGION=0  # 0=us-east-1, 1=us-west-1, 2=eu-west-1, etc.
AWS_S3_ACCESS_KEY=VOTRE_ACCESS_KEY_ID
AWS_S3_SECRET_KEY=VOTRE_SECRET_ACCESS_KEY

# Client Configuration
VITE_API_URL=http://localhost:3000
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
