# Database Configuration
# Option 1: Connection string (used by Render in production)
# DATABASE_URL=postgres://user:password@host:5432/whynot

# Option 2: Individual params (used by docker-compose / local dev)
DB_HOST=localhost
DB_PORT=54321
DB_NAME=whynot
DB_USER=postgres
DB_PASSWORD=postgres

# Application
JWT_SECRET=your-secret-key-change-this-in-production
PORT=3000
NODE_ENV=development

# CORS (only needed in development)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Agora RTC
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Cloudinary (Image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# OAuth Configuration
GOOGLE_CLIENT_ID=xxx
GOOGLE_CLIENT_SECRET=xxx
APPLE_CLIENT_ID=com.whynot.web
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_KEY_ID=XXXXXXXXXX
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Mailjet configuration
MAILJET_API_KEY="xxx"
MAILJET_SECRET_KEY="yyy"
MAILJET_FROM_EMAIL="email@domain.com"
MAILJET_FROM_NAME="your name or company"

# AWS SES (waiting list confirmation emails from no-reply@popup-live.fr)
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

FRONTEND_URL=https://popup-live.fr

# Mondial Relay Connect API
MONDIAL_RELAY_CUSTOMER_ID=BDTEST13
MONDIAL_RELAY_API_KEY=your_api_key_here
# Override the API base URL (defaults to production — test credentials also use prod)
# MONDIAL_RELAY_BASE_URL=https://connect.mondialrelay.com/api/v5

# Client Configuration
VITE_API_URL=http://localhost:3000
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_POSTHOG_KEY=...
VITE_POSTHOG_HOST=https://eu.i.posthog.com
