# ============================================
# WhyNot Docker Environment Variables
# ============================================
# This file is used when running the app via Docker Compose or standalone Docker container
# Copy this file to .env and fill in your actual values

# ----------------------
# Database (PostgreSQL)
# ----------------------
# For Docker Compose, use service name "postgres"
# For standalone container, use "host.docker.internal"
DB_HOST=postgres
DB_PORT=5432
DB_NAME=whynot
DB_USER=postgres
DB_PASSWORD=postgres

# Alternative DATABASE_URL format (if your app uses this instead)
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/whynot

# ----------------------
# Redis
# ----------------------
# For Docker Compose, use service name "redis"
# For standalone container, use "host.docker.internal"
REDIS_URL=redis://redis:6379

# ----------------------
# Application
# ----------------------
NODE_ENV=production
PORT=3000
JWT_SECRET=your-secret-key-change-in-production

# ----------------------
# CORS (development only)
# ----------------------
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ----------------------
# Agora RTC (required)
# ----------------------
# Get from: https://console.agora.io
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_certificate
AGORA_CUSTOMER_ID=your_customer_id
AGORA_CUSTOMER_SECRET=your_customer_secret

# ----------------------
# Cloudflare Stream (required)
# ----------------------
# Get from: https://dash.cloudflare.com
CLOUDFLARE_STREAM_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_STREAM_API_TOKEN=your_cloudflare_api_token

# ----------------------
# Stripe (required)
# ----------------------
# Get from: https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ----------------------
# AWS S3 (optional)
# ----------------------
AWS_S3_BUCKET=whynot-agora-recordings
AWS_S3_REGION=0  # 0=us-east-1, 1=us-west-1, 2=eu-west-1, etc.
AWS_S3_ACCESS_KEY=your_aws_access_key_id
AWS_S3_SECRET_KEY=your_aws_secret_access_key

# ----------------------
# Client Configuration
# ----------------------
# These are injected at build time for the Vite frontend
VITE_API_URL=http://localhost:3000
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
